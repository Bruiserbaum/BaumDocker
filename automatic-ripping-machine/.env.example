# ── Cluster placement (Docker Swarm) ─────────────────────────────────────────
# Hostname of the swarm node this stack should run on (SATA/bulk tier).
# ARM needs a physical optical drive attached, so it must always land on the
# node where /dev/sr0 (and your rip output paths) exist.
# Must match: docker node ls --format '{{.Hostname}}'
BULK_NODE=TuringPICompute3

# ── Identity ──────────────────────────────────────────────────────────────────
# Must match the arm user on the host. Run setup.sh to set these automatically,
# or manually: id -u arm  /  id -g arm

ARM_UID=1000
ARM_GID=1000

# ── Timezone ──────────────────────────────────────────────────────────────────
# Used for rip timestamps and scheduled tasks.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

TZ=America/New_York

# ── Storage paths ─────────────────────────────────────────────────────────────
# ARM_HOME    — base directory for ARM's working files (database, UI state)
# ARM_LOGS    — rip and transcode log files
# ARM_CONFIG  — arm.yaml and supporting config files
# ARM_MEDIA   — DVD/Blu-ray rip output (point this at GlusterFS or a large drive)
# ARM_MUSIC   — CD audio rip output (point this at GlusterFS or a large drive)
#
# Default: everything under /home/arm (local storage).
# GlusterFS example:
#   ARM_MEDIA=/mnt/gluster/arm/media
#   ARM_MUSIC=/mnt/gluster/arm/music
#
# Make sure the target directories exist and are owned by ARM_UID:ARM_GID
# before starting the container.

ARM_HOME=/home/arm
ARM_LOGS=/home/arm/logs
ARM_CONFIG=/home/arm/config
ARM_MEDIA=/mnt/gluster-bulk/arm/media
ARM_MUSIC=/mnt/gluster-bulk/arm/music

# ── ARM configuration ─────────────────────────────────────────────────────────
# These settings are written into arm.yaml on first run and can also be
# changed later via the ARM web UI (Settings tab) or by editing
# ${ARM_CONFIG}/arm.yaml directly.
#
# ARM reads arm.yaml — not Docker environment variables — for these options.
# The values below are the ARM defaults; uncomment and change as needed.

# Transcoding
# TRANSCODE=true                  # Transcode ripped content with HandBrake
# TRANSCODE_MOVIE=true            # Transcode movies
# TRANSCODE_TV=true               # Transcode TV episodes
# TRANSCODE_MUSIC=false           # Transcode audio (usually not needed)
# HANDBRAKE_CLI_PRESET=HQ 1080p30 Surround  # HandBrake preset name

# Rip behaviour
# RIPMETHOD=mkv                   # mkv = MakeMKV (default), dd = raw disc copy
# MAINFEATURE=false               # true = rip only the longest title (main feature)
# MINLENGTH=600                   # Minimum title length in seconds to rip
# MAXLENGTH=99999                 # Maximum title length in seconds to rip
# EXTRAS=true                     # Rip bonus features and extras

# Metadata
# METADATA_PROVIDER=tmdb          # tmdb or omdb
# TMDB_API_KEY=REPLACE_WITH_API_KEY
# OMDB_API_KEY=REPLACE_WITH_API_KEY

# Notifications (Apprise-compatible — see https://github.com/caronc/apprise)
# NOTIFY_RIP=false                # Notify when a rip starts
# NOTIFY_TRANSCODE=false          # Notify when transcoding completes
# APPRISE_URL=                    # e.g. discord://webhook_id/webhook_token

# MakeMKV
# MAKEMKV_KEY=REPLACE_WITH_KEY    # MakeMKV beta key (for Blu-ray)
