# ── Database ───────────────────────────────────────────────────────────────────
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
# Generate with: openssl rand -hex 32
WORDPRESS_DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
MYSQL_ROOT_PASSWORD=REPLACE_WITH_ROOT_PASSWORD

# ── WordPress security keys ────────────────────────────────────────────────────
# Generate all four at: https://api.wordpress.org/secret-key/1.1/salt/
# Or with: openssl rand -hex 32  (run four times)
WORDPRESS_AUTH_KEY=REPLACE_WITH_HEX_SECRET
WORDPRESS_SECURE_AUTH_KEY=REPLACE_WITH_HEX_SECRET
WORDPRESS_LOGGED_IN_KEY=REPLACE_WITH_HEX_SECRET
WORDPRESS_NONCE_KEY=REPLACE_WITH_HEX_SECRET
