# ── Storage ────────────────────────────────────────────────────────────────────
# Absolute path on the HOST where photos/videos will be stored.
# Point this at your external/NAS drive.
UPLOAD_LOCATION=/mnt/your-drive/immich/photos

# Absolute path on the HOST for the ML model cache (face recognition, CLIP, etc.)
# Can be on the same drive or a faster local disk.
ML_MODEL_CACHE=/mnt/your-drive/immich/model-cache

# Absolute path on the HOST for the PostgreSQL data directory.
# Recommend keeping this on a fast local drive, not a spinning external.
DB_DATA_LOCATION=/mnt/your-drive/immich/postgres

# ── Immich version ─────────────────────────────────────────────────────────────
# Pin to a specific version (e.g. v1.117.0) or use "release" for latest stable.
IMMICH_VERSION=release

# ── Database ───────────────────────────────────────────────────────────────────
DB_USERNAME=immich
DB_DATABASE_NAME=immich
# Generate with: openssl rand -hex 32
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# ── Server URL ─────────────────────────────────────────────────────────────────
# The URL clients (mobile app, browser) use to reach Immich.
# Required if accessing from outside your LAN or through a reverse proxy.
# IMMICH_SERVER_URL=https://photos.yourdomain.com
