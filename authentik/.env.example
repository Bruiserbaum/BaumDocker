# ── Authentik ─────────────────────────────────────────────────────────────────

# Authentik version tag — pin to a specific release
# Check https://github.com/goauthentik/authentik/releases for the latest
#
# ⚠ UPGRADE WARNING: Authentik cannot skip major version series.
# You MUST upgrade step-by-step through intermediate releases or gunicorn
# will fail to start because the database migrations are incompatible.
#
# Required upgrade path to reach 2026.2.1:
#   Step 1: AUTHENTIK_TAG=2025.2.4  → docker compose up -d → wait for healthy
#   Step 2: AUTHENTIK_TAG=2025.6.4  → docker compose up -d → wait for healthy
#   Step 3: AUTHENTIK_TAG=2026.2.1  → docker compose up -d
#
# If upgrading from 2024.12.x, start at Step 1.
AUTHENTIK_TAG=2026.2.1

# Secret key — generate with: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=REPLACE_WITH_HEX_SECRET

# Web UI ports — defaults changed from 9000/9443 (conflicts with Portainer)
AUTHENTIK_HTTP_PORT=9100
AUTHENTIK_HTTPS_PORT=9144

# ── PostgreSQL ────────────────────────────────────────────────────────────────

PG_USER=authentik
PG_DB=authentik

# Generate with: openssl rand -hex 32
PG_PASS=REPLACE_WITH_HEX_SECRET

# ── Email (optional — for password resets and notifications) ──────────────────
# Uncomment and fill in to enable outbound email from Authentik.
# Must be set in both the server and worker environment blocks in docker-compose.yml.

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=you@example.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_USE_TLS=true
# EMAIL_FROM=Authentik <authentik@example.com>

# ── Timezone ──────────────────────────────────────────────────────────────────

TZ=America/Chicago
