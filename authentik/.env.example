# ── Cluster placement (Docker Swarm) ─────────────────────────────────────────
# Hostname of the swarm node this stack should run on (NVMe/fast tier).
# All four services (postgresql, redis, server, worker) are pinned here so
# they stay co-located and named volumes are always found on the right node.
# Must match: docker node ls --format '{{.Hostname}}'
FAST_NODE=TuringPiRK1

# ── Authentik ─────────────────────────────────────────────────────────────────

# Authentik version tag.
# "latest" always pulls the newest stable release on `docker compose pull`.
# To pin to a specific version instead, replace with e.g. AUTHENTIK_TAG=2026.2.1
#
# ⚠ UPGRADE WARNING: If you were previously pinned to an old version and are
# switching to latest, you may need to upgrade step-by-step through intermediate
# releases — see README for the safe upgrade path.
AUTHENTIK_TAG=latest

# Secret key — generate with: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=REPLACE_WITH_HEX_SECRET

# Web UI ports — defaults changed from 9000/9443 (conflicts with Portainer)
AUTHENTIK_HTTP_PORT=9100
AUTHENTIK_HTTPS_PORT=9144

# ── PostgreSQL ────────────────────────────────────────────────────────────────

PG_USER=authentik
PG_DB=authentik

# Generate with: openssl rand -hex 32
PG_PASS=REPLACE_WITH_HEX_SECRET

# ── Email (optional — for password resets and notifications) ──────────────────
# Uncomment and fill in to enable outbound email from Authentik.
# Must be set in both the server and worker environment blocks in docker-compose.yml.

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=you@example.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_USE_TLS=true
# EMAIL_FROM=Authentik <authentik@example.com>

# ── Timezone ──────────────────────────────────────────────────────────────────

TZ=America/Chicago
