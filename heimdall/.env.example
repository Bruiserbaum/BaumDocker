# ── Timezone & permissions ──────────────────────────────────────────────────────
# Set to your local timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# Run as your host user to avoid permission issues with the config folder.
# Find yours with: id -u  /  id -g
PUID=1000
PGID=1000
