# ── Auth ───────────────────────────────────────────────────────────────────────
# Your public-facing URL — used for auth callbacks.
# Example: https://karakeep.yourdomain.com  or  http://your-server-ip:3000
NEXTAUTH_URL=REPLACE_WITH_YOUR_URL

# Secret for signing auth tokens. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_WITH_HEX_SECRET

# ── Search (Meilisearch) ────────────────────────────────────────────────────────
# Must be the same value in both the web and meilisearch services.
# Generate with: openssl rand -hex 32
MEILI_MASTER_KEY=REPLACE_WITH_HEX_SECRET

# ── AI summarization (optional) ────────────────────────────────────────────────
# Remove or leave blank to disable AI summarization.
OPENAI_API_KEY=REPLACE_WITH_API_KEY
