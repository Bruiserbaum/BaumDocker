# ── Storage ────────────────────────────────────────────────────────────────────
# Absolute path on the HOST for vault data, attachments, and config.
DATA_FOLDER=/opt/vaultwarden/data

# ── Server ─────────────────────────────────────────────────────────────────────
# The URL clients use to reach Vaultwarden (required for correct redirect/invite links).
# Include the protocol — e.g. https://vault.yourdomain.com
DOMAIN=https://vault.yourdomain.com

# ── Admin ──────────────────────────────────────────────────────────────────────
# Token to access the /admin panel. Generate with: openssl rand -base64 48
# Leave unset to disable the admin panel entirely.
ADMIN_TOKEN=REPLACE_WITH_ADMIN_TOKEN

# ── Signups ────────────────────────────────────────────────────────────────────
# Set to true to allow new account registrations. Disable after creating your accounts.
SIGNUPS_ALLOWED=false

# ── SMTP (optional) ────────────────────────────────────────────────────────────
# Required for email verification, password hints, and invite links.
# SMTP_HOST=smtp.yourdomain.com
# SMTP_FROM=vaultwarden@yourdomain.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
# SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
