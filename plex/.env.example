# ── Cluster placement (Docker Swarm) ─────────────────────────────────────────
# Hostname of the swarm node this stack should run on (SATA/bulk tier).
# Must match: docker node ls --format '{{.Hostname}}'
BULK_NODE=TuringPICompute3

# ── Media storage — absolute paths on the HOST drive ──────────────────────────
MOVIES_PATH=/mnt/gluster-bulk/media/movies
TV_PATH=/mnt/gluster-bulk/media/tv
MUSIC_PATH=/mnt/gluster-bulk/media/music
# Optional: fast local disk for transcode scratch files (default: /tmp/plex-transcode)
TRANSCODE_PATH=/tmp/plex-transcode

# ── Plex account ───────────────────────────────────────────────────────────────
# Get a one-time claim token at https://plex.tv/claim (expires in 4 minutes)
# Remove this line after the server is claimed on first start.
PLEX_CLAIM=REPLACE_WITH_CLAIM_TOKEN

# ── System ─────────────────────────────────────────────────────────────────────
TZ=America/Chicago
PUID=1000
PGID=1000
