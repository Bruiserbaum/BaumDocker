# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD

# ── Nextcloud admin account (used only on first run) ──────────────────────────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD

# ── Trusted domains ────────────────────────────────────────────────────────────
# Space-separated list of hostnames/IPs Nextcloud will accept requests from.
# Add your server IP, local hostname, and/or external domain.
NEXTCLOUD_TRUSTED_DOMAINS=localhost 192.168.1.100 cloud.yourdomain.com
