# ─────────────────────────────────────────────────────────────
# AI Stack — Environment Variables
# Copy this file to .env and fill in all values before starting
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────


# ── LibreChat login settings ──────────────────────────────────
# Set to true/false to control login options.
# If using Authentik SSO, set both to false.

LIBRECHAT_ALLOW_EMAIL_LOGIN=true
LIBRECHAT_ALLOW_REGISTRATION=false
LIBRECHAT_ALLOW_SOCIAL_LOGIN=false
# Required for OAuth/OIDC redirect URLs to work correctly behind a reverse proxy
LIBRECHAT_DOMAIN_CLIENT=https://librechat.yourdomain.com
LIBRECHAT_DOMAIN_SERVER=https://librechat.yourdomain.com


# ── LibreChat secrets ─────────────────────────────────────────
# Five separate secrets — generate a unique value for each one

LIBRECHAT_JWT_SECRET=
LIBRECHAT_CREDS_KEY=
LIBRECHAT_SESSION_SECRET=
LIBRECHAT_REFRESH_TOKEN_SECRET=
LIBRECHAT_JWT_REFRESH_SECRET=


# ── AnythingLLM secrets ───────────────────────────────────────

ANYTHINGLLM_JWT_SECRET=


# ── n8n secrets ───────────────────────────────────────────────

N8N_ENCRYPTION_KEY=
N8N_USER_MANAGEMENT_JWT_SECRET=


# ── n8n config ────────────────────────────────────────────────
# Set to your public domain if behind a reverse proxy (nginx-proxy-manager etc.)
# Used for webhook URLs shown in the n8n UI

N8N_WEBHOOK_URL=http://localhost:5678


# ── Timezone ──────────────────────────────────────────────────
# Used by n8n for scheduled workflow triggers
# Examples: America/New_York  America/Chicago  America/Los_Angeles  Europe/London

TIMEZONE=America/New_York


# ── OpenAI API key (optional) ─────────────────────────────────
# Used by LibreChat and AnythingLLM as a fallback cloud model source
# Leave blank or remove if running fully local with Ollama only

OPENAI_API_KEY=


# ── OpenHands (AI coding agent) ───────────────────────────────
# Web UI available at http://<host>:3002
# OpenHands uses LiteLLM routing — prefix model name with "ollama/"
# to use your local Ollama instance

OPENHANDS_LLM_MODEL=ollama/qwen3-coder:30b-a3b-q4_K_M


# ── LibreChat Authentik SSO (optional) ────────────────────────
# Enable OpenID Connect login for LibreChat via Authentik.
# In Authentik: create an OAuth2/OpenID Provider and an Application.
# Set the redirect URI to: http://your-server-ip:3000/oauth/openid/callback
# When SSO is enabled, consider setting ALLOW_REGISTRATION=false
# and ALLOW_EMAIL_LOGIN=false in docker-compose.yml.
#
# LIBRECHAT_OPENID_ISSUER=https://auth.yourdomain.com/application/o/<app-slug>/
# LIBRECHAT_OPENID_CLIENT_ID=REPLACE_WITH_CLIENT_ID
# LIBRECHAT_OPENID_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
# LIBRECHAT_OPENID_SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET
# LIBRECHAT_OPENID_SCOPE=openid profile email
# LIBRECHAT_OPENID_CALLBACK_URL=/oauth/openid/callback
# LIBRECHAT_OPENID_BUTTON_LABEL=Login with Authentik
