# ─────────────────────────────────────────────────────────────
# mailcow.conf — Primary Mailcow configuration file
# Copy to mailcow.conf and fill in all values before starting.
#
# This file is sourced by Mailcow's docker-compose.yml.
# Generate it automatically with:
#   ./generate_config.sh
# or fill in the values below manually.
# ─────────────────────────────────────────────────────────────


# ── Hostname ──────────────────────────────────────────────────
# The fully qualified domain name of your mail server.
# Must have a valid A record and reverse DNS (PTR) entry.
# Example: mail.yourdomain.com

MAILCOW_HOSTNAME=mail.yourdomain.com


# ── Timezone ──────────────────────────────────────────────────
# Examples: America/New_York  Europe/London  America/Chicago

TZ=America/New_York


# ── Database ──────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32

DBNAME=mailcow
DBUSER=mailcow
DBPASS=
DBROOT=


# ── Secrets ───────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32

REDISPASS=


# ── HTTP/HTTPS ports ──────────────────────────────────────────
# Change if ports 80/443 are already in use on your host.
# If behind a reverse proxy, you can use non-standard ports here
# and proxy 80/443 externally.

HTTP_PORT=80
HTTPS_PORT=443
HTTP_BIND=0.0.0.0
HTTPS_BIND=0.0.0.0


# ── Mail ports ────────────────────────────────────────────────
# Standard mail ports — only change if you have a specific reason.

SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190


# ── SSL / ACME ────────────────────────────────────────────────
# SKIP_LETS_ENCRYPT=y   — use if you supply your own cert or are behind a proxy
# SKIP_IP_CHECK=y       — skip IP check for ACME (use behind NAT)
# ADDITIONAL_SAN=       — extra SANs to add to the Let's Encrypt cert (comma-separated)

SKIP_LETS_ENCRYPT=n
SKIP_IP_CHECK=n
ADDITIONAL_SAN=


# ── ClamAV ────────────────────────────────────────────────────
# Set to y to disable ClamAV (reduces RAM usage by ~500 MB).

SKIP_CLAMD=n


# ── Solr (full-text search) ───────────────────────────────────
# Set to y to disable Solr (reduces RAM usage).

SKIP_SOLR=y


# ── IPv6 ──────────────────────────────────────────────────────
# Set to y if your host does not have IPv6.

SNAT_TO_SOURCE=
SNAT6_TO_SOURCE=


# ── API ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32

API_KEY=
API_KEY_READ_ONLY=
API_ALLOW_FROM=127.0.0.1,::1
