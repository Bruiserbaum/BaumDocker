# ── Cluster placement (Docker Swarm) ─────────────────────────────────────────
# Hostname of the swarm node this stack should run on (NVMe/fast tier).
# Must match: docker node ls --format '{{.Hostname}}'
FAST_NODE=TuringPiRK1

# ── Core ─────────────────────────────────────────────────────────────────────

# Fully qualified domain name for this MeshCentral instance.
# Must match what your reverse proxy forwards and what agents connect to.
HOSTNAME=mesh.yourdomain.com

# Allow new users to self-register (true/false).
# Leave false and create accounts manually in the web UI.
ALLOW_NEW_ACCOUNTS=false

# Enable WebRTC tunneling (true/false). Requires TURN/STUN server for NAT traversal.
WEBRTC=false

# Allow the MeshCentral UI to be embedded in an iframe (true/false).
IFRAME=false

# Minify JavaScript/CSS served to the browser (true/false).
MINIFY=true

# Enable plugins (true/false).
ALLOW_PLUGINS=false

# ── Reverse Proxy (Nginx Proxy Manager) ───────────────────────────────────────

# IP address of your Nginx/NPM container as seen from the MeshCentral container.
# When set, MeshCentral switches to TLS-offload mode — it accepts plain HTTP
# from the proxy and trusts X-Forwarded-For headers.
# Find the NPM container IP with: docker inspect nginx-proxy-manager | grep IPAddress
# Leave blank if you are not using a reverse proxy.
REVERSE_PROXY=

# The external HTTPS port your reverse proxy listens on (usually 443).
REVERSE_PROXY_TLS_PORT=443

# ── MongoDB (optional — remove # to enable) ───────────────────────────────────
# The default embedded NeDB database is fine for up to ~100 devices.
# For larger deployments, switch to MongoDB by uncommenting these and changing
# the image to ghcr.io/ylianst/meshcentral:latest-mongodb in docker-compose.yml.

# USE_MONGODB=true
# MONGO_URL=mongodb://meshcentral:REPLACE_WITH_MONGO_PASSWORD@mongodb:27017/meshcentral
