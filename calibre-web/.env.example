# ── Timezone & permissions ──────────────────────────────────────────────────────
# Set to your local timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# Run as your host user to avoid permission issues.
# Find yours with: id -u  /  id -g
PUID=1000
PGID=1000

# ── Library path ───────────────────────────────────────────────────────────────
# Absolute path on the HOST to your Calibre library folder.
# Must contain a metadata.db file (created by the Calibre desktop app).
BOOKS_PATH=/mnt/gluster-bulk/calibre
