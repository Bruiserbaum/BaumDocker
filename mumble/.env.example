# ── SuperUser ──────────────────────────────────────────────────────────────────
# Password for the SuperUser account — used to administer the server via Mumble client.
# Change this before starting the server for the first time.
MUMBLE_SUPERUSER_PASSWORD=REPLACE_WITH_SUPERUSER_PASSWORD

# ── Server identity ────────────────────────────────────────────────────────────
# Name shown in the public server list and Mumble client browser.
MUMBLE_CONFIG_SERVERNAME=My Mumble Server

# Welcome message shown to users when they connect.
MUMBLE_CONFIG_WELCOMETEXT=Welcome to the server.

# ── Limits ─────────────────────────────────────────────────────────────────────
# Maximum simultaneous users (0 = unlimited).
MUMBLE_CONFIG_USERS=50

# Per-user bandwidth limit in bits/second (72000 = 72 kbps).
MUMBLE_CONFIG_BANDWIDTH=72000

# ── Public listing ─────────────────────────────────────────────────────────────
# Set to true to register this server on the public Mumble server list.
MUMBLE_CONFIG_REGISTERPUBLICSERVER=false

# ── Timezone ───────────────────────────────────────────────────────────────────
TZ=America/Chicago
